flowchart TD
    A[Run benchmark] --> B[Collect metrics + theorem metadata]
    B --> C[Write full_results.csv / json]
    B --> D[Filter theorem-certified rows]
    B --> E[Filter auxiliary rows]

    D --> D1{Theorem table rules}
    D1 --> R1[theorem_certified=True]
    D1 --> R2[theorem_mode_used=True]
    D1 --> R3[exclude interval_dfs_fallback]
    D1 --> R4[exclude prototype_case_split]
